{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vegas-sidekick",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "vegassidekick.com", "custom_domain": true },
    { "pattern": "www.vegassidekick.com", "custom_domain": true }
  ]
}
